; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Godot GameInput Tests"
config/features=PackedStringArray("4.6")

[autoload]

GameInputBootstrap="*res://addons/godot_gameinput/runtime/gameinput_bootstrap.gd"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_gameinput/plugin.cfg")

[game_input]

runtime/initialize_on_startup=false
runtime/auto_poll=false
mapper/default_action_map=""

[rendering]

rendering_device/driver="d3d12"
rendering_device/driver.windows="d3d12"
